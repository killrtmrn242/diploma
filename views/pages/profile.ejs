<%- include("../partials/header") %>
<%- include("../partials/navbar") %>

<main class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-8">
      <div class="auth-card">
        <div class="d-flex flex-wrap justify-content-between gap-3 align-items-center mb-4">
          <div>
            <span class="eyebrow">Profile</span>
            <h1 class="section-title mb-0">Authenticated user details</h1>
          </div>
          <% if (authMethod === "session") { %>
            <span class="badge bg-session">Session</span>
          <% } else if (authMethod === "jwt") { %>
            <span class="badge bg-jwt">JWT</span>
          <% } else { %>
            <span class="badge bg-oauth">OAuth 2.0</span>
          <% } %>
        </div>

        <div class="profile-layout">
          <div class="profile-main">
            <div class="profile-row">
              <span class="info-label">User ID</span>
              <div class="info-value"><%= user._id %></div>
            </div>
            <div class="profile-row">
              <span class="info-label">Email</span>
              <div class="info-value"><%= user.email %></div>
            </div>
            <div class="profile-row">
              <span class="info-label">Auth method</span>
              <div class="info-value text-capitalize"><%= authMethod %></div>
            </div>
            <div class="profile-row">
              <span class="info-label">Created at</span>
              <div class="info-value"><%= new Date(user.createdAt).toLocaleString() %></div>
            </div>
            <div class="profile-row">
              <span class="info-label">OAuth provider</span>
              <div class="info-value"><%= user.oauthProvider || "Not connected" %></div>
            </div>
            <div class="profile-row">
              <span class="info-label">Linked methods</span>
              <div class="info-value"><%= user.authMethods.join(", ") %></div>
            </div>
          </div>

          <% if (user.avatar) { %>
            <div class="profile-aside">
              <img src="<%= user.avatar %>" alt="User avatar" class="avatar-preview" />
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</main>

<%- include("../partials/footer") %>
